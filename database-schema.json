{
  "database_name": "Registro de Gastos e Ingresos",
  "description": "Personal finance database fed from iPhone via iOS Shortcuts + Notion API",
  "fields": [
    {"name": "Nombre", "type": "title", "required": true},
    {"name": "Valor", "type": "number", "format": "dollar", "note": "USD amount"},
    {"name": "Valor COP", "type": "number", "note": "COP amount"},
    {"name": "Moneda", "type": "select", "options": ["USD", "COP"]},
    {"name": "Tipo", "type": "select", "options": ["Ingreso", "Gasto Variable", "Gasto Fijo", "Obligacion", "Inversion", "Ahorro", "Deuda"]},
    {"name": "Cuenta", "type": "select", "options": ["PayPal", "Bancolombia", "Nequi", "Efectivo", "Rappi", "trii.co"]},
    {"name": "Categoria", "type": "select", "options": ["Trabajo", "Negocio", "Alimentacion", "Transporte", "Salud y Ejercicio", "Educacion e Ingles", "Servicios Digitales", "Entretenimiento", "Seguridad Social", "ETFs Inversion", "Ahorro Emergencia", "Deuda Tarjeta", "Vivienda", "Personal"]},
    {"name": "Fecha", "type": "date", "format": "ISO 8601"},
    {"name": "Notas", "type": "rich_text", "required": false},
    {"name": "ID", "type": "unique_id", "prefix": "TXN", "auto": true},
    {"name": "Fecha de creacion", "type": "created_time", "auto": true}
  ]
}
